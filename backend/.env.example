# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Main database — game user (limited permissions)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# Main database — admin user (full CRUD on word tables)
DB_ADMIN_USER=your_admin_db_user
DB_ADMIN_PASS=your_admin_db_password

# Typegame / leaderboard database (separate PostgreSQL database)
TYPEGAME_HOST=localhost
TYPEGAME_PORT=5432
TYPEGAME_DB=your_typegame_db_name
TYPEGAME_USER=your_typegame_db_user
TYPEGAME_PASS=your_typegame_db_password
